# ──────────────────────────────────────────────────────────────
# Ruang Tenang Mobile - Environment configuration (EXAMPLE)
#
# Copy this file to `.env` and fill in the values for local dev:
#   cp .env.example .env
#
# Resolution order at runtime (highest priority first):
#   1. --dart-define values (used by CI/CD)
#   2. values from this .env file
#   3. safe defaults (platform-aware localhost for development)
# ──────────────────────────────────────────────────────────────

# App environment: development | staging | production
ENVIRONMENT=development

# API base URL (host only, WITHOUT the /api/v1 prefix).
#
# Examples:
#   Development (ngrok) : https://thankful-midge-noble.ngrok-free.app
#   Production          : https://api.ruang-tenang.site
#
# Leave empty to fall back to the platform-aware localhost logic
# (Android emulator -> 10.0.2.2, iOS sim -> localhost, etc).
BASE_URL=
